# ═══════════════════════════════════════════════════════════════
# TRADING SYSTEM — ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your keys.
# Lines starting with # are comments. Empty values are optional.

# ── Exchange: Binance ──
# Testnet: https://testnet.binance.vision/
# Live: https://www.binance.com/en/user/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET_KEY=
BINANCE_TESTNET_SECRET=

# ── Exchange: Bybit (USDT linear / CCXT) ──
# PriceFetcher reads EITHER pair below (same secret values — use one pair only).
# Primary names (match most docs): demo/live keys from Bybit → API management.
BYBIT_API_KEY=
BYBIT_API_SECRET=
# Alternate names (still supported — src/data/fetcher.py checks these too):
BYBIT_TESTNET_KEY=
BYBIT_TESTNET_SECRET=
# Paper testnet: keys from https://testnet.bybit.com/app/user/api-management → use any of the four vars above.
# Demo trading API (api-demo.bybit.com): set BYBIT_DEMO=true with demo keys (if your runner enables demo URLs).
BYBIT_DEMO=
# true/1 when your Bybit account uses hedge mode (separate long/short). Must match account or orders may fail.
# Also configurable as execution.bybit_hedge_mode in config.yaml.
BYBIT_HEDGE_MODE=

# ── Exchange: Alpaca (code reads these exact names) ──
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
# Optional override; default paper URL is set in code if unset.
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# ── Exchange: Delta (optional mirror) — align with config.yaml execution.delta_* ──
# DELTA_API_KEY=
# DELTA_API_SECRET=
# DELTA_TESTNET=true
# DELTA_INDIA_DEMO=true
# DELTA_MIRROR=true

# ── Market data: LiveCoinWatch ──
# Not used when the active exchange is Bybit (PriceFetcher uses Bybit-only paths).
LIVECOINWATCH_API_KEY=
# Set to 1 to skip LCW entirely (any exchange).
# DISABLE_LIVECOINWATCH=

# ── News & Sentiment APIs ──
# NewsAPI: https://newsapi.org/register
NEWSAPI_KEY=
# CryptoPanic: https://cryptopanic.com/developers/api/
CRYPTOPANIC_TOKEN=

# ── LLM: cloud (Gemini / etc.) ──
# Google Gemini: https://aistudio.google.com/apikey
REASONING_LLM_KEY=
# Set to 1 to prefer local Ollama and skip Gemini when both could apply.
DISABLE_GEMINI=

# ── macOS / ML stacks (avoid libomp segfault with PyTorch + LightGBM + sklearn) ──
# Defaults are applied in src/main.py if unset. Increase only after fixing duplicate OpenMP.
# OMP_NUM_THREADS=1
# MKL_NUM_THREADS=1
# OPENBLAS_NUM_THREADS=1
# VECLIB_MAXIMUM_THREADS=1
# KMP_DUPLICATE_LIB_OK=TRUE

# ── LLM: Ollama (local / remote) — keep in sync with config.yaml ai.* ──
# Typical setup: one Ollama on :11434 with qwen2.5:3b for all AI (executor, brain, strategist, agents).
# config.yaml: ai.ollama_base_url + ai.reasoning_model; monitor.ollama_url + monitor.ollama_model.
# Provider order: registered names, e.g. local (see config ai.llm_provider_order).
LLM_PROVIDER_ORDER=local
# Local `ollama serve` (default). If OLLAMA_HOST or OLLAMA_BASE_URL is set, it wins over OLLAMA_REMOTE_URL (trade executor + LLM router).
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_BASE_URL=
# Tunnel / remote GPU only — leave empty for local-only; remote-only: unset OLLAMA_HOST and set this.
OLLAMA_REMOTE_URL=
OLLAMA_SKIP_LOCAL=0
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_REMOTE_MODEL=qwen2.5:3b
OLLAMA_REMOTE_TIMEOUT=120
LLM_BASE_URL=

# ── LLM: Anthropic (optional monitoring / agents) ──
ANTHROPIC_API_KEY=

# ── Sentiment Analysis Layer (L2) ──
# 1 = disable FinBERT (rule-based fallback). 0 = enable (needs HuggingFace token for some setups).
DISABLE_FINBERT=0
HUGGINGFACE_TOKEN=

# ═══════════════════════════════════════════════════════════════
# FREE DATA SOURCES (no key — already integrated)
# ═══════════════════════════════════════════════════════════════
# Alternative.me Fear & Greed, Deribit public, CoinGecko, DefiLlama,
# Blockchain.com, Mempool.space, Binance futures L/S (public), yfinance, CCXT prices.

# ═══════════════════════════════════════════════════════════════
# OPTIONAL FREE-TIER APIs (signup, $0)
# ═══════════════════════════════════════════════════════════════
# Dune: https://dune.com/
DUNE_API_KEY=

# ═══════════════════════════════════════════════════════════════
# PAID-TIER PLACEHOLDERS (add key to activate)
# ═══════════════════════════════════════════════════════════════
GLASSNODE_API_KEY=
CRYPTOQUANT_API_KEY=
WHALE_ALERT_API_KEY=
COINGLASS_API_KEY=

# ═══════════════════════════════════════════════════════════════
# DASHBOARD & MONITORING
# ═══════════════════════════════════════════════════════════════
# Streamlit dashboard (:8501): set DASHBOARD_PASS to require login; empty = dev (no auth).
DASHBOARD_API_KEY=
DASHBOARD_USER=
DASHBOARD_PASS=

# Local broker dashboard: python -m src.main --broker-dashboard  or  --dashboard  (Flask, default :5000)
# MONITOR_OLLAMA_URL=
# MONITOR_OLLAMA_MODEL=

ALERT_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Journal encryption (optional — use a long random string)
JOURNAL_ENCRYPTION_KEY=

# Model bundle integrity (optional — set to match packaged manifest)
MODEL_MANIFEST_HASH=

# ═══════════════════════════════════════════════════════════════
# OTHER OPTIONAL SERVICES
# ═══════════════════════════════════════════════════════════════
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_2FA=
