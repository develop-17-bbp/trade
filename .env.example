# ═══════════════════════════════════════════════════════════════
# TRADING SYSTEM — ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your keys.
# Lines starting with # are comments. Empty values are optional.

# ── Exchange Credentials ──
# Get testnet keys from: https://testnet.binance.vision/
# Get live keys from: https://www.binance.com/en/user/settings/api-management
BINANCE_API_KEY=your_binance_live_api_key_here
BINANCE_API_SECRET=your_binance_live_api_secret_here
BINANCE_TESTNET_KEY=your_binance_testnet_api_key_here
BINANCE_TESTNET_SECRET=your_binance_testnet_api_secret_here

# ── News & Sentiment APIs ──
# NewsAPI: https://newsapi.org/register (free: 100 req/day)
NEWSAPI_KEY=your_newsapi_key_here
# CryptoPanic: https://cryptopanic.com/developers/api/ (free tier)
CRYPTOPANIC_TOKEN=your_cryptopanic_token_here

# ── LLM Reasoning (L6 Strategist) ──
# Google Gemini: https://aistudio.google.com/apikey (free tier)
REASONING_LLM_KEY=your_google_gemini_api_key_here

# ── Sentiment Analysis Layer (L2) ──
# Set to '1' to disable FinBERT transformer (uses rule-based fallback)
# Set to '0' to enable FinBERT transformer (requires HuggingFace)
DISABLE_FINBERT=0
HUGGINGFACE_TOKEN=

# ═══════════════════════════════════════════════════════════════
# FREE DATA SOURCES (No API key required — already integrated)
# ═══════════════════════════════════════════════════════════════
# These work out of the box with zero configuration:
#   - Alternative.me Fear & Greed Index
#   - Deribit Options IV & Put/Call Ratio (public API)
#   - CoinGecko Market Data (30 req/min free tier)
#   - DefiLlama DeFi TVL, DEX Volume, Stablecoin Flows
#   - Blockchain.com BTC Network Stats
#   - Mempool.space BTC Mempool & Hashrate
#   - Binance Futures L/S Ratio (public)
#   - Yahoo Finance Macro Data (via yfinance)
#   - CCXT Multi-Exchange Prices (Binance, Bybit, OKX)

# ═══════════════════════════════════════════════════════════════
# OPTIONAL: FREE-TIER APIs (Need signup but cost $0)
# ═══════════════════════════════════════════════════════════════

# Dune Analytics — On-chain SQL queries
# Signup: https://dune.com/ (free tier: 2500 credits/month)
DUNE_API_KEY=

# ═══════════════════════════════════════════════════════════════
# PAID-TIER PLACEHOLDERS (Code ready — just add key to activate)
# ═══════════════════════════════════════════════════════════════

# Glassnode — Institutional on-chain analytics (LTH metrics, SOPR, NUPL)
# Signup: https://studio.glassnode.com/
# Cost: Starter $29/mo | Professional $799/mo
# Features: exchange_inflow/outflow, lth_supply_ratio, sopr, nupl, mvrv
GLASSNODE_API_KEY=

# CryptoQuant — Exchange flows, miner data
# Signup: https://cryptoquant.com/
# Cost: Professional $99/mo
# Features: exchange_flows, miner_outflow, estimated_leverage_ratio
CRYPTOQUANT_API_KEY=

# Whale Alert — Real-time large transfer tracking
# Signup: https://whale-alert.io/
# Cost: Free (10 req/min) | Pro $9.99/mo (100 req/min)
# Features: whale transfers >$500K, from/to exchange labels
WHALE_ALERT_API_KEY=

# CoinGlass — Aggregated derivatives data
# Signup: https://www.coinglass.com/
# Cost: Free (limited) | Pro $49/mo
# Features: liquidation heatmap, aggregated L/S ratio, multi-exchange OI
COINGLASS_API_KEY=

# ═══════════════════════════════════════════════════════════════
# DASHBOARD & MONITORING
# ═══════════════════════════════════════════════════════════════

# Dashboard authentication (leave empty for dev mode / no auth)
DASHBOARD_API_KEY=
DASHBOARD_USER=
DASHBOARD_PASS=

# Alerting (optional)
ALERT_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Journal encryption (optional — set any 32+ char string)
JOURNAL_ENCRYPTION_KEY=

# ═══════════════════════════════════════════════════════════════
# OTHER OPTIONAL SERVICES
# ═══════════════════════════════════════════════════════════════
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
ROBINHOOD_2FA=
