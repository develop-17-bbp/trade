{
  "annotations": {
    "list": []
  },
  "description": "ACT v8 — Phase 1 observability overview. Decision latency, agent votes, authority violations, LLM tokens, equity.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Decision latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "refId": "p50",
          "expr": "histogram_quantile(0.50, sum(rate(act_decision_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "refId": "p95",
          "expr": "histogram_quantile(0.95, sum(rate(act_decision_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "refId": "p99",
          "expr": "histogram_quantile(0.99, sum(rate(act_decision_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 2,
      "title": "Decisions / sec by action",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (action) (rate(act_decisions_total[5m]))",
          "legendFormat": "{{action}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Agent vote distribution (last 1h)",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 9},
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "text"
      },
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (agent, direction) (increase(act_agent_votes_total[1h]))",
          "legendFormat": "{{agent}} / {{direction}}",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Authority violations (1h)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 9},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 10}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(act_authority_violations_total[1h]))",
          "legendFormat": "violations"
        }
      ]
    },
    {
      "id": 5,
      "title": "Equity (USD)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 9},
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 0}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(act_equity_usd)",
          "legendFormat": "TOTAL"
        }
      ]
    },
    {
      "id": 6,
      "title": "LLM tokens / sec",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 14},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (model) (rate(act_llm_tokens_total[5m]))",
          "legendFormat": "{{model}}"
        }
      ]
    }
  ],
  "refresh": "15s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["act", "phase-1"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {"refresh_intervals": ["5s", "10s", "15s", "30s", "1m", "5m"]},
  "timezone": "browser",
  "title": "ACT Overview",
  "uid": "act-overview",
  "version": 1,
  "weekStart": ""
}
