# ── Python ──
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Secrets ──
.env
.env.*
*.env

# ── Runtime Data ──
# Logs: bot-generated, noisy, machine-specific. Keep folder via .gitkeep.
logs/*
!logs/.gitkeep

# Backtest cache: regenerable from parquet + code
data/backtest_cache/

# Runtime state JSON files the bot rewrites every cycle
data/adaptation_context.json
data/adaptive_state.json
data/autonomous_state.json
data/evolution_feedback.json
data/evolution_state.json
data/halt_signal.json
data/ops_retry_tracker.json
data/finetune/

# Memory DBs — per-host runtime state, not versioned
memory/*.db
memory/*.db.bak
memory/*.sqlite

# LoRA adapter dirs (large, regenerable via lora_trainer)
models/lora/
models/*.bak.*

authority_trade_summaries/
reports/

# ── Infra stack ──
# Local service data (Prometheus TSDB, Grafana state, Redis AOF, Tempo blocks)
infra/volumes/
# Local Grafana password override (stored next to docker-compose.yml)
infra/.env

# Cloudflare tunnel — generated config holds tunnel UUID + credentials path
infra/cloudflared/config.yml
infra/cloudflared/*.json

# ── OS ──
.DS_Store
# Thumbs.db

# ── IDE ──
.vscode/
.idea/
*.swp
